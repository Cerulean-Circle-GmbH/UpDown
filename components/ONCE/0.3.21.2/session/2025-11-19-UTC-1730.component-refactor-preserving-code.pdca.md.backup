### **Phase 3: Component Implementations (Extract from ServerHierarchyManager)**

#### **File**: `src/ts/layer2/DefaultHTTPSServer.ts` (NEW)

**Methods Extracted from ServerHierarchyManager**:
- `startHttpServer(port)` → Keep logic, make OOP
- `handleHttpRequest(req, res)` → Delegate to Router
- `createTlsConfig()` → Delegate to LetsEncrypt
- `getVersionFromPath()` → Keep as-is
- `calculateProjectRoot()` → Keep as-is

```typescript
import { IncomingMessage, ServerResponse, Server, createServer } from 'http';
import { createServer as createHttpsServer, Server as HttpsServer } from 'https';
import { Scenario } from '../layer3/Scenario.interface.js';
import { HTTPSServerModel } from '../layer3/HTTPSServerModel.interface.js';
import { LifecycleState } from '../layer3/LifecycleState.enum.js';
import { ServerRole } from '../layer3/ServerRole.enum.js';
import { DefaultRouter } from './DefaultRouter.js';
import { RouterModel } from '../layer3/RouterModel.interface.js';
import { DefaultLetsEncrypt } from './DefaultLetsEncrypt.js';
import { LetsEncryptModel } from '../layer3/LetsEncryptModel.interface.js';
import { NodeOSInfrastructure } from '../layer1/NodeOSInfrastructure.js';
import * as path from 'path';
import { fileURLToPath } from 'url';

/**
 * HTTPS Server Component
 * ✅ Empty constructor + init(scenario) pattern
 * ✅ Reuses ServerHierarchyManager HTTP logic
 * ✅ Delegates routing to Router component
 * ✅ Delegates TLS to LetsEncrypt component
 */
export class DefaultHTTPSServer {
  // ✅ Model (serializable data only)
  private data!: HTTPSServerModel;
  
  // ✅ Component instances (behavior, not serialized)
  private httpServer?: Server | HttpsServer;
  private router?: DefaultRouter;
  private certUpdater?: DefaultLetsEncrypt;
  private infrastructure?: NodeOSInfrastructure;
  
  /**
   * ✅ Empty constructor (Web4 pattern)
   */
  constructor() {
    // Empty - all initialization in init()
  }
  
  /**
   * ✅ Initialize from scenario (Web4 pattern)
   */
  init(scenario: Scenario<HTTPSServerModel>): this {
    if (!this.data) {
      // ✅ Path Authority (calculate once)
      const projectRoot = this.calculateProjectRoot();
      const eamdPath = path.join(projectRoot, 'EAMD.ucp');
      
      this.data = {
        uuid: crypto.randomUUID(),
        state: LifecycleState.CREATED,
        role: ServerRole.CLIENT,  // Default, will be set by port manager
        hostname: 'localhost',
        domain: 'local.once',
        host: 'localhost',
        ip: '127.0.0.1',
        tlsEnabled: false,
        projectRoot,
        componentsDir: path.join(projectRoot, 'components'),
        eamdPath,
        wwwRoot: eamdPath,
        pid: process.pid,
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
      };
    }
    
    // ✅ Inject scenario data
    if (scenario.model) {
      Object.assign(this.data, scenario.model);
    }
    
    // ✅ Create infrastructure
    this.infrastructure = new NodeOSInfrastructure();
    
    return this;
  }
  
  /**
   * ✅ Detect and set environment (from ServerHierarchyManager)
   * REUSED METHOD - unchanged logic
   */
  async detectAndSetEnvironment(): Promise<void> {
    if (!this.infrastructure) {
      throw new Error('Infrastructure not initialized. Call init() first.');
    }
    
    const env = await this.infrastructure.detectEnvironment();
    this.data.hostname = env.getHostname();
    this.data.host = env.getFqdn();
    this.data.ip = env.getPrimaryIP();
    this.data.domain = env.getDomain();
    this.data.updatedAt = new Date().toISOString();
  }
  
  /**
   * ✅ Start HTTP/HTTPS server (from ServerHierarchyManager.startHttpServer)
   * REUSED METHOD - extracted and cleaned up
   */
  async start(port: number, role: string): Promise<void> {
    this.data.state = LifecycleState.STARTING;
    this.data.role = role;
    this.data.httpPort = port;
    
    // ✅ Initialize Router component
    await this.initializeRouter();
    
    // ✅ Create server (HTTP or HTTPS)
    if (this.data.tlsEnabled && this.data.tlsCertPath) {
      // ✅ HTTPS server with TLS
      await this.initializeLetsEncrypt();
      const tlsConfig = this.createTlsConfig();
      this.httpServer = createHttpsServer(tlsConfig, (req, res) => this.handleRequest(req, res));
    } else {
      // ✅ HTTP server (fallback)
      this.httpServer = createServer((req, res) => this.handleRequest(req, res));
    }
    
    // ✅ Start listening
    await new Promise<void>((resolve, reject) => {
      this.httpServer!.listen(port, () => {
        this.data.state = LifecycleState.RUNNING;
        this.data.updatedAt = new Date().toISOString();
        console.log(`🟢 ${this.data.role === ServerRole.PRIMARY ? 'PRIMARY' : 'CLIENT'} HTTPS Server running on ${this.data.host}:${port}`);
        resolve();
      });
      this.httpServer!.on('error', reject);
    });
  }
  
  /**
   * ✅ Handle HTTP request (from ServerHierarchyManager.handleHttpRequest)
   * REFACTORED - delegates to Router instead of switch/case
   */
  private async handleRequest(req: IncomingMessage, res: ServerResponse): Promise<void> {
    const pathname = new URL(req.url || '/', `http://${req.headers.host}`).pathname;
    const method = req.method || 'GET';
    
    if (!this.router) {
      res.writeHead(500, { 'Content-Type': 'text/plain' });
      res.end('Router not initialized');
      return;
    }
    
    // ✅ Delegate to Router (Radical OOP, no switch/case)
    await this.router.route(pathname, method, req, res);
  }
  
  /**
   * ✅ Initialize Router component
   */
  private async initializeRouter(): Promise<void> {
    const routerScenario = new Scenario<RouterModel>().init({
      ior: {
        uuid: crypto.randomUUID(),
        component: 'Router',
        version: this.getVersionFromPath()
      },
      owner: '',
      model: {
        uuid: crypto.randomUUID(),
        state: LifecycleState.CREATED,
        routeIORs: [],
        totalRequests: 0,
        totalHits: 0,
        totalMisses: 0,
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
      }
    });
    
    this.router = new DefaultRouter();
    this.router.init(routerScenario);
    
    // ✅ Add default routes (from ServerHierarchyManager switch/case)
    await this.router.addDefaultRoutes(this.data);
    
    // ✅ Store Router IOR
    const routerIor = this.router.toScenario();
    this.data.routerIOR = routerIor.ior.uuid;
  }
  
  /**
   * ✅ Initialize LetsEncrypt component
   */
  private async initializeLetsEncrypt(): Promise<void> {
    if (!this.data.tlsEnabled) return;
    
    const certScenario = new Scenario<LetsEncryptModel>().init({
      ior: {
        uuid: crypto.randomUUID(),
        component: 'LetsEncrypt',
        version: this.getVersionFromPath()
      },
      owner: '',
      model: {
        uuid: crypto.randomUUID(),
        state: LifecycleState.CREATED,
        domain: this.data.domain,
        email: 'admin@' + this.data.domain,
        certsDir: path.join(this.data.projectRoot, 'certs'),
        certificateExists: false,
        autoRenewEnabled: true,
        renewalCheckInterval: 86400000,  // 24 hours
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
      }
    });
    
    this.certUpdater = new DefaultLetsEncrypt();
    this.certUpdater.init(certScenario);
    
    // ✅ Acquire or load certificates
    await this.certUpdater.ensureCertificates();
    
    // ✅ Update model with cert paths
    const certModel = this.certUpdater.getModel();
    this.data.tlsCertPath = certModel.certPath;
    this.data.tlsKeyPath = certModel.keyPath;
    this.data.tlsCaPath = certModel.caPath;
    this.data.certUpdaterIOR = certScenario.ior.uuid;
  }
  
  /**
   * ✅ Create TLS config (from ServerHierarchyManager)
   * REUSED METHOD - unchanged logic
   */
  private createTlsConfig(): any {
    if (!this.data.tlsCertPath || !this.data.tlsKeyPath) {
      throw new Error('TLS certificate paths not configured');
    }
    
    const fs = require('fs');
    return {
      cert: fs.readFileSync(this.data.tlsCertPath),
      key: fs.readFileSync(this.data.tlsKeyPath),
      ca: this.data.tlsCaPath ? fs.readFileSync(this.data.tlsCaPath) : undefined
    };
  }
  
  /**
   * ✅ Calculate project root (from ServerHierarchyManager)
   * REUSED METHOD - unchanged logic
   */
  private calculateProjectRoot(): string {
    const __filename = fileURLToPath(import.meta.url);
    const __dirname = path.dirname(__filename);
    return path.resolve(__dirname, '../../../..');
  }
  
  /**
   * ✅ Get version from path (from ServerHierarchyManager)
   * REUSED METHOD - unchanged logic
   */
  private getVersionFromPath(): string {
    const __filename = fileURLToPath(import.meta.url);
    const versionMatch = __filename.match(/ONCE[\/\\]([\d.]+)[\/\\]/);
    return versionMatch ? versionMatch[1] : '0.3.21.2';
  }
  
  /**
   * ✅ Stop server gracefully
   */
  async stop(): Promise<void> {
    this.data.state = LifecycleState.STOPPING;
    
    if (this.httpServer) {
      await new Promise<void>((resolve) => {
        this.httpServer!.close(() => {
          this.data.state = LifecycleState.STOPPED;
          this.data.updatedAt = new Date().toISOString();
          console.log(`⚪ HTTPS Server stopped on port ${this.data.httpPort}`);
          resolve();
        });
      });
    }
  }
  
  /**
   * ✅ Save as scenario (Web4 pattern)
   */
  toScenario(): Scenario<HTTPSServerModel> {
    return new Scenario<HTTPSServerModel>().init({
      ior: {
        uuid: this.data.uuid,
        component: 'HTTPSServer',
        version: this.getVersionFromPath()
      },
      owner: '',
      model: { ...this.data }
    });
  }
  
  /**
   * ✅ JavaBean getters
   */
  getModel(): HTTPSServerModel {
    return { ...this.data };
  }
  
  getUUID(): string {
    return this.data.uuid;
  }
  
  getState(): string {
    return this.data.state;
  }
  
  getPort(): number | undefined {
    return this.data.httpPort;
  }
  
  getRole(): string {
    return this.data.role;
  }
}
```

**Key Features**:
- ✅ Reuses proven ServerHierarchyManager HTTP logic
