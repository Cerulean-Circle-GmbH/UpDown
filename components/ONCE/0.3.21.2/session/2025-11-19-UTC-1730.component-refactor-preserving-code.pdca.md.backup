```typescript
/**
 * Server Role Enum
 * ✅ Static readonly for type safety
 */
export class ServerRole {
  static readonly PRIMARY = 'primary' as const;
  static readonly CLIENT = 'client' as const;
  static readonly STANDALONE = 'standalone' as const;
  
  static readonly ALL = [
    ServerRole.PRIMARY,
    ServerRole.CLIENT,
    ServerRole.STANDALONE
  ] as const;
  
  static isValid(role: string): boolean {
    return ServerRole.ALL.includes(role as any);
  }
}
```

**One File One Type**: ✅ Only `ServerRole` class.

