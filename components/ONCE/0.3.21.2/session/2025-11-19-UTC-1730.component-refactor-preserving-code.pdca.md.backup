import { Scenario } from '../layer3/Scenario.interface.js';
import { PrimaryServerModel } from '../layer3/PrimaryServerModel.interface.js';
import { WebSocket, WebSocketServer } from 'ws';
import * as fs from 'fs';
import * as path from 'path';

/**
 * Primary Server Component (Registry + Housekeeping)
 * ✅ Empty constructor + init(scenario) pattern
 * ✅ Reuses ServerHierarchyManager registry logic
 */
export class DefaultPrimaryServer {
  // ✅ Model (serializable data only)
  private data!: PrimaryServerModel;
  
  // ✅ Component instances (behavior, not serialized)
  private serverRegistry: Map<string, any> = new Map();
  private wsServer?: WebSocketServer;
  private housekeepingTimer?: NodeJS.Timeout;
  
  constructor() {
    // Empty - all initialization in init()
  }
  
  init(scenario: Scenario<PrimaryServerModel>): this {
    if (!this.data) {
      this.data = {
        uuid: crypto.randomUUID(),
        state: 'created',
        registeredServerIORs: [],
        housekeepingInterval: 300000,  // 5 minutes
        housekeepingEnabled: true,
        staleServerTimeout: 600000,    // 10 minutes
        totalServersRegistered: 0,
        totalServersStopped: 0,
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
      };
    }
    
    if (scenario.model) {
      Object.assign(this.data, scenario.model);
    }
    
    return this;
  }
  
  /**
   * ✅ Start housekeeping (from ServerHierarchyManager)
   * REUSED METHOD - unchanged logic
   */
  startHousekeeping(scenariosDir: string): void {
    if (!this.data.housekeepingEnabled) return;
    
    this.housekeepingTimer = setInterval(async () => {
      await this.performHousekeeping(scenariosDir);
    }, this.data.housekeepingInterval);
    
    console.log(`🧹 Housekeeping started (interval: ${this.data.housekeepingInterval / 1000}s)`);
  }
  
  /**
   * ✅ Perform housekeeping (from ServerHierarchyManager)
   * REUSED METHOD - unchanged logic
   */
  private async performHousekeeping(scenariosDir: string): Promise<void> {
    console.log('🧹 Starting housekeeping...');
    
    // TODO: Implement housekeeping logic from ServerHierarchyManager
    // - Scan scenario files
    // - Check process PIDs
    // - Clean up stale scenarios
    
    this.data.lastHousekeepingRun = new Date().toISOString();
    this.data.updatedAt = new Date().toISOString();
    
    console.log('✅ Housekeeping complete');
  }
  
  /**
   * ✅ Register client server (from ServerHierarchyManager)
   * REUSED METHOD - unchanged logic
   */
  registerClient(serverIOR: string, websocket: WebSocket): void {
    this.serverRegistry.set(serverIOR, {
      ior: serverIOR,
      websocket,
      registeredAt: new Date().toISOString()
    });
    
    this.data.registeredServerIORs.push(serverIOR);
    this.data.totalServersRegistered++;
    this.data.updatedAt = new Date().toISOString();
    
    console.log(`📋 Registered client server: ${serverIOR}`);
  }
  
  /**
   * ✅ Broadcast to clients (from ServerHierarchyManager)
   * REUSED METHOD - unchanged logic
   */
  broadcastToClients(message: any): void {
    const messageStr = JSON.stringify(message);
    
    this.serverRegistry.forEach((entry, ior) => {
      if (entry.websocket && entry.websocket.readyState === WebSocket.OPEN) {
        entry.websocket.send(messageStr);
      }
    });
    
    console.log(`📡 Broadcasted to ${this.serverRegistry.size} client(s)`);
  }
  
  toScenario(): Scenario<PrimaryServerModel> {
    return new Scenario<PrimaryServerModel>().init({
      ior: {
        uuid: this.data.uuid,
        component: 'PrimaryServer',
        version: '0.3.21.2'
      },
      owner: '',
      model: { ...this.data }
    });
  }
  
  getModel(): PrimaryServerModel {
    return { ...this.data };
  }
}
