#### **File**: `src/ts/layer2/DefaultONCE.ts` (MODIFIED)

```typescript
import { ONCE } from '../layer3/ONCE.interface.js';
import { ONCEModel } from '../layer3/ONCEModel.interface.js';
import { Scenario } from '../layer3/Scenario.interface.js';
import { DefaultHTTPSServer } from './DefaultHTTPSServer.js';
import { DefaultPrimaryServer } from './DefaultPrimaryServer.js';
import { HTTPSServerModel } from '../layer3/HTTPSServerModel.interface.js';
import { PrimaryServerModel } from '../layer3/PrimaryServerModel.interface.js';
import { ServerRole } from '../layer3/ServerRole.enum.js';
import { PortManager } from './PortManager.js';
import * as path from 'path';
import { fileURLToPath } from 'url';

/**
 * DefaultONCE - kernel that loads components
 * ✅ Loads HTTPSServer component
 * ✅ Loads PrimaryServer component (if primary role)
 */
export class DefaultONCE implements ONCE {
  private data!: ONCEModel;
  
  // ✅ Component instances (not in model)
  private httpsServer?: DefaultHTTPSServer;
  private primaryServer?: DefaultPrimaryServer;
  private portManager: PortManager;
  
  constructor() {
    this.portManager = PortManager.getInstance();
  }
  
  init(scenario: Scenario<ONCEModel>): this {
    if (!this.data) {
      const projectRoot = this.calculateProjectRoot();
      
      this.data = {
        uuid: crypto.randomUUID(),
        name: 'ONCE',
        description: 'Object Network Communication Engine Enhanced',
        state: 'booting',
        environment: 'node',
        domain: 'local.once',
        host: 'localhost',
        projectRoot,
        componentsDir: path.join(projectRoot, 'components'),
        eamdPath: path.join(projectRoot, 'EAMD.ucp'),
        scenariosDir: path.join(projectRoot, 'scenarios'),
        loadedComponents: [],
        capabilities: [],
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
      };
    }
    
    if (scenario.model) {
      Object.assign(this.data, scenario.model);
    }
    
    return this;
  }
  
  /**
   * ✅ Start server (loads HTTPSServer and PrimaryServer components)
   */
  async startServer(): Promise<void> {
    this.data.state = 'loading';
    
    // ✅ Get port and role from PortManager
    const portResult = await this.portManager.getNextAvailablePort();
    const role = portResult.isPrimary ? ServerRole.PRIMARY : ServerRole.CLIENT;
    
    // ✅ Create HTTPSServer scenario
    const httpsScenario = new Scenario<HTTPSServerModel>().init({
      ior: {
        uuid: crypto.randomUUID(),
        component: 'HTTPSServer',
        version: this.getVersionFromPath()
      },
      owner: '',
      model: {
        uuid: crypto.randomUUID(),
        state: 'created',
        role,
        hostname: 'localhost',
        domain: 'local.once',
        host: 'localhost',
        ip: '127.0.0.1',
        httpPort: portResult.port,
        tlsEnabled: false,
        projectRoot: this.data.projectRoot,
        componentsDir: this.data.componentsDir,
        eamdPath: this.data.eamdPath,
        wwwRoot: this.data.eamdPath,
        pid: process.pid,
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString()
      }
    });
    
    // ✅ Load HTTPSServer component
    this.httpsServer = new DefaultHTTPSServer();
    this.httpsServer.init(httpsScenario);
    await this.httpsServer.detectAndSetEnvironment();
    await this.httpsServer.start(portResult.port, role);
    
    this.data.loadedComponents.push(httpsScenario.ior);
    
    // ✅ If PRIMARY, load PrimaryServer component
    if (role === ServerRole.PRIMARY) {
      const primaryScenario = new Scenario<PrimaryServerModel>().init({
        ior: {
          uuid: crypto.randomUUID(),
          component: 'PrimaryServer',
          version: this.getVersionFromPath()
        },
        owner: '',
        model: {
          uuid: crypto.randomUUID(),
          state: 'created',
          registeredServerIORs: [],
          housekeepingInterval: 300000,
          housekeepingEnabled: true,
          staleServerTimeout: 600000,
          totalServersRegistered: 0,
          totalServersStopped: 0,
          createdAt: new Date().toISOString(),
          updatedAt: new Date().toISOString()
        }
      });
      
      this.primaryServer = new DefaultPrimaryServer();
      this.primaryServer.init(primaryScenario);
      this.primaryServer.startHousekeeping(this.data.scenariosDir);
      
      this.data.loadedComponents.push(primaryScenario.ior);
    }
    
    this.data.state = 'ready';
    this.data.updatedAt = new Date().toISOString();
  }
  
  private calculateProjectRoot(): string {
    const __filename = fileURLToPath(import.meta.url);
    const __dirname = path.dirname(__filename);
    return path.resolve(__dirname, '../../../..');
  }
  
  private getVersionFromPath(): string {
    const __filename = fileURLToPath(import.meta.url);
    const versionMatch = __filename.match(/ONCE[\/\\]([\d.]+)[\/\\]/);
    return versionMatch ? versionMatch[1] : '0.3.21.2';
  }
  
  toScenario(): Scenario<ONCEModel> {
    return new Scenario<ONCEModel>().init({
      ior: {
        uuid: this.data.uuid,
        component: 'ONCE',
        version: this.getVersionFromPath()
      },
      owner: '',
      model: { ...this.data }
    });
  }
}
```

**Key Features**:
- ✅ ONCE as kernel (loads components)
- ✅ Loads HTTPSServer component
- ✅ Loads PrimaryServer component (if primary)
- ✅ No direct HTTP/HTTPS code (delegated)

