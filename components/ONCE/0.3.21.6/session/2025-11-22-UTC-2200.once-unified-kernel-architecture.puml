title ONCE Unified Kernel Architecture\nEnvironment-Agnostic P2P Kernel

package "Layer 1: Infrastructure & Environment Detection" as Layer1 <<Rectangle>> {
  
  class ONCE <<singleton>> #LAYER1_COLOR {
    {static} - instance: ONCE | null
    {static} - environment: string | null
    {static} - kernel: ONCEKernel | null
    --
    {static} + start(scenario?: any): Promise<ONCEKernel>
    {static} - detectEnvironment(): string
    {static} - loadKernel(env: string): Promise<ONCEKernel>
    {static} + getInstance(): ONCEKernel
  }
  
  interface EnvironmentInfo {
    + type: string
    + isNode: boolean
    + isBrowser: boolean
    + isWorker: boolean
    + isServiceWorker: boolean
    + isPWA: boolean
    + version: string
    + capabilities: string[]
  }
  
  note right of ONCE
    **Entry Point for ALL Environments**
    
    Detects:
    - Node.js server
    - Browser (window)
    - Web Worker
    - Service Worker
    - PWA context
    
    Then loads appropriate kernel
    implementation from Layer 2
  end note
}

package "Layer 2: Kernel Implementations" as Layer2 <<Rectangle>> {
  
  abstract class AbstractONCEKernel <<abstract>> #LAYER2_COLOR {
    # model: ONCEKernelModel | null
    --
    + constructor()
    + {abstract} init(scenario: any): Promise<this>
    + {abstract} getHealth(): Promise<any>
    + {abstract} invokeMethod(method: string, params: any): Promise<any>
    + {abstract} start(): Promise<void>
    + {abstract} stop(): Promise<void>
  }
  
  class DefaultONCE extends AbstractONCEKernel #LAYER2_COLOR {
    - model: ONCEServerModel
    - hierarchyManager: ServerHierarchyManager
    - httpServer: any
    - wsServer: any
    --
    + init(scenario: ONCEServerScenario): Promise<this>
    + getHealth(): Promise<any>
    + invokeMethod(method, params): Promise<any>
    + start(): Promise<void>
    + stop(): Promise<void>
    + getPeers(): Promise<any>
    + registerComponent(component): void
  }
  
  class BrowserONCEKernel extends AbstractONCEKernel #LAYER2_COLOR {
    - model: ONCEBrowserModel
    - pollingInterval: any
    --
    + init(scenario: ONCEBrowserScenario): Promise<this>
    + getHealth(): Promise<any>
    + invokeMethod(method, params): Promise<any>
    + start(): Promise<void>
    + stop(): Promise<void>
    + connect(): Promise<void>
    + getPeers(): Promise<any>
    + pollUpdates(): void
  }
  
  class WorkerONCEKernel extends AbstractONCEKernel #LAYER2_COLOR {
    - model: ONCEWorkerModel
    --
    + init(scenario: ONCEWorkerScenario): Promise<this>
    + getHealth(): Promise<any>
    + invokeMethod(method, params): Promise<any>
    + start(): Promise<void>
    + stop(): Promise<void>
    + postMessage(message: any): void
  }
  
  class ServiceWorkerONCEKernel extends AbstractONCEKernel #LAYER2_COLOR {
    - model: ONCESWModel
    - cache: Cache
    --
    + init(scenario: ONCESWScenario): Promise<this>
    + getHealth(): Promise<any>
    + invokeMethod(method, params): Promise<any>
    + start(): Promise<void>
    + stop(): Promise<void>
    + handleFetch(request: Request): Promise<Response>
  }
  
  note right of AbstractONCEKernel
    **All kernels share same interface**
    
    Empty constructor (Radical OOP)
    State in this.model
    Methods operate on model
    No arrow functions, no callbacks
  end note
}

package "Layer 3: Interfaces & Types" as Layer3 <<Rectangle>> {
  
  interface ONCEKernel <<interface>> #LAYER3_COLOR {
    + model: any
    + init(scenario: any): Promise<this>
    + getHealth(): Promise<any>
    + invokeMethod(method: string, params: any): Promise<any>
    + start(): Promise<void>
    + stop(): Promise<void>
