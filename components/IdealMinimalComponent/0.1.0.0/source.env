#!/bin/bash
# Web4Articles Project Environment Setup
# Version: 0.1.0.0 - SIMPLIFIED Scenario-based completion
# TypeScript-first approach: Minimal shell, maximum TypeScript
# 
# IMPORTANT: This file is auto-managed by web4tscomponent initProject
# - Timestamp-based sync: Newer templates overwrite older source.env
# - To revert to latest: Run `web4tscomponent initProject`
# - To use specific version: Run `web4tscomponent-vX.X.X.X initProject`

# Useful aliases
alias ll='ls -la'

# Project Root
# For test isolation: Use pwd directly (test/data is the virtual project root)
# For production: Use git root or pwd as fallback
if [[ "$PWD" =~ /test/data$ ]]; then
  # We're in test/data - use pwd as project root
  export WEB4_PROJECT_ROOT="$(pwd)"
else
  # Production - use git root or pwd
export WEB4_PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
fi

# Add scripts to PATH
export PATH="$WEB4_PROJECT_ROOT/scripts:$WEB4_PROJECT_ROOT/scripts/versions:$PATH"

# Enable single TAB completion display
bind 'set show-all-if-ambiguous on'

# ============================================================================
# 🎯 Tab Completion Setup - SIMPLIFIED ONE-LINE GREP PROTOCOL
# ============================================================================

# Initialize completion log
_web4_init_completion_log() {
    local logfile="$WEB4_PROJECT_ROOT/temp/logs/completion-debug.log"
    mkdir -p "$(dirname "$logfile")" 2>/dev/null || true
    > "$logfile"  # Truncate to empty on source
}

# Generic completion function (works for ALL Web4 CLIs)
# NEW: Scenario-based approach - bash only touches 2 fields!
_web4_generic_completion() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local cli="${COMP_WORDS[0]}"
    local logfile="$WEB4_PROJECT_ROOT/temp/logs/completion-debug.log"
    local result display words
    
    # Log start
    {
        echo "=== $(date -u '+%Y-%m-%d %H:%M:%S') ==="
        echo "CLI: $cli"
        echo "CWORD: $COMP_CWORD"
        echo "COMP_WORDS: ${COMP_WORDS[*]}"
    } >> "$logfile"
    
    # Show "Thinking..." for user feedback (newline before for clean display)
    printf "\n💭 Thinking...\n"
    
    # SIMPLIFIED: Use shCompletion API (direct parameter passing - no JSON manipulation!)
    echo "Calling shCompletion with COMP_CWORD=$COMP_CWORD, COMP_WORDS=[${COMP_WORDS[*]}]" >> "$logfile"
    result=$(timeout 30s "$cli" shCompletion "$COMP_CWORD" "${COMP_WORDS[@]}" 2>>"$logfile" || true)
    
    if [ -z "$result" ]; then
        echo "❌ Failed to get completion results from shCompletion" >> "$logfile"
        COMPREPLY=()
        return 1
    fi
    
    echo "Got shCompletion result: ${result:0:200}..." >> "$logfile"
    
    # Handle timeout
    if [ $? -eq 124 ]; then
        echo "⏱️ TIMEOUT after 90s" >> "$logfile"
        printf "\n⏱️  Completion timed out (>90s)\n"
            COMPREPLY=()
            return 0
        fi
        
    echo "Complete output: '$result'" >> "$logfile"
    
    # FIXED: Process DISPLAY lines with ANSI rendering (addresses Test 1.9.2.1.2.b, 1.9.2.1.5.b)
    display=$(echo "$result" | grep "^DISPLAY: " | cut -d' ' -f2-)
    
    # Extract WORD values (for completion)
    words=$(echo "$result" | grep "^WORD: " | cut -d' ' -f2- | xargs)
    echo "Extracted words: '$words'" >> "$logfile"
    
    # Count words for single-match auto-complete
    local word_count=$(echo "$words" | wc -w | tr -d ' ')
    echo "Word count: $word_count" >> "$logfile"
    
    # FIXED: Single match TSDoc documentation restoration (addresses Test 1.9.2.1.4.b)
    if [ "$word_count" -eq 1 ]; then
        # For single match, show full display content (including TSDoc if present)
        if [ -n "$display" ]; then
            # Process display lines without subshell to avoid printf issues
            while IFS= read -r line; do
                # Special handling for prompt line (contains "your" and "web4" and "command" with ANSI codes)
                if [[ "$line" == *"your"* && "$line" == *"web4"* && "$line" == *"command"* ]]; then
                    printf "%b" "$line"  # No newline for prompt
                else
                    echo -e "$line"      # Normal newline for other lines
                fi
            done <<< "$display"
        fi
        COMPREPLY=("$words")
        echo "COMPREPLY (single): ${COMPREPLY[*]}" >> "$logfile"
        return 0
    fi
    
    # Multiple matches: Show hierarchical display
    if [ -n "$display" ]; then
        # Process display lines without subshell to avoid printf issues
        while IFS= read -r line; do
            # Special handling for prompt line (contains "your" and "web4" and "command" with ANSI codes)
            if [[ "$line" == *"your"* && "$line" == *"web4"* && "$line" == *"command"* ]]; then
                printf "%b" "$line"  # No newline for prompt
            else
                echo -e "$line"      # Normal newline for other lines
            fi
        done <<< "$display"
    fi
    
    # Multiple words = use compgen filtering
    COMPREPLY=($(compgen -W "$words" -- "$cur"))
    echo "COMPREPLY (compgen): ${COMPREPLY[*]}" >> "$logfile"
    echo "---" >> "$logfile"
}

# Auto-register completions for all CLIs
_web4_auto_register_completions() {
    local scripts="$WEB4_PROJECT_ROOT/scripts"
    local registered=()
    
    [ ! -d "$scripts" ] && return 0
    
    for cli in "$scripts"/*; do
        # Skip if not executable or is directory
        [ -x "$cli" ] && [ ! -d "$cli" ] || continue
        
        local name=$(basename "$cli")
        
        # Skip versioned CLIs in main scripts/ - they're in scripts/versions/
        [[ "$name" =~ -v[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+ ]] && continue
        
        # Only register if symlink points to component with TSCompletion
        if [ -L "$cli" ]; then
            local target=$(readlink "$cli")
            if [[ "$target" =~ components/([^/]+)/latest ]]; then
                local comp="${BASH_REMATCH[1]}"
                local tsc="$WEB4_PROJECT_ROOT/components/$comp/latest/src/ts/layer4/TSCompletion.ts"
                
                if [ -f "$tsc" ]; then
                    # Register completion
                    complete -F _web4_generic_completion -o nospace "$name"
                    registered+=("$name")
                fi
            fi
        fi
    done
    
    # Also register versioned CLIs from scripts/versions/
    if [ -d "$scripts/versions" ]; then
        for cli in "$scripts/versions"/*; do
            # Skip if not executable or is directory
            [ -x "$cli" ] && [ ! -d "$cli" ] || continue
            
            local name=$(basename "$cli")
            
            # Only register versioned CLIs (e.g., web4tscomponent-v0.3.17.4)
            [[ "$name" =~ -v[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+ ]] || continue
            
            # Register completion for versioned CLI
            if [ -L "$cli" ]; then
                local target=$(readlink "$cli")
                if [[ "$target" =~ components/([^/]+)/([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+) ]]; then
                    local comp="${BASH_REMATCH[1]}"
                    local ver="${BASH_REMATCH[2]}"
                    local tsc="$WEB4_PROJECT_ROOT/components/$comp/$ver/src/ts/layer4/TSCompletion.ts"
                    
                    if [ -f "$tsc" ]; then
                        # Register completion
                        complete -F _web4_generic_completion -o nospace "$name"
                        registered+=("$name")
                    fi
                fi
            fi
        done
    fi
    
    # Silent registration - no output
}

# Initialize log and register completions
_web4_init_completion_log
_web4_auto_register_completions

# Set COMPONENT_VERSION for PS1 display
# Dynamically resolve version from web4tscomponent latest symlink
if [ -L "$WEB4_PROJECT_ROOT/components/Web4TSComponent/latest" ]; then
    # Read what latest points to (should be a version like "0.3.17.4")
    LATEST_VERSION=$(readlink "$WEB4_PROJECT_ROOT/components/Web4TSComponent/latest")
    if [[ "$LATEST_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        export COMPONENT_VERSION="$LATEST_VERSION"
    else
        export COMPONENT_VERSION="Project Root"
    fi
else
    export COMPONENT_VERSION="Project Root"
fi

# OOSH-inspired colored PS1 prompt for Web4
export PS1="\[\e[0m\][web4 \[\e[36m\]${COMPONENT_VERSION} | \u\[\e[0m\]@\[\e[32m\]\h\[\e[0m\]] \[\e[33;1m\]\w\[\e[0m\] > "

# Check if running in test isolation mode
if [[ "$PWD" =~ /test/data$ ]]; then
    # Extract version from path: /components/{Name}/{Version}/test/data
    if [[ "$PWD" =~ /components/([^/]+)/([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+)/test/data$ ]]; then
        test_component="${BASH_REMATCH[1]}"
        test_version="${BASH_REMATCH[2]}"
        
        # Set ISOLATED prompt to make it VERY visible
        export PS1="\[\033[1;36m\][ISOLATED web4 ${test_component}/${test_version}]\[\033[0m\] \[\033[1;33m\]\w\[\033[0m\] > "
        
# PIGGY HARDCODE (test isolation only): Force completion registration
# Normal auto-discovery expects symlinks, but isolated CLI is direct Node wrapper
complete -F _web4_generic_completion -o nospace web4tscomponent
    fi
fi
