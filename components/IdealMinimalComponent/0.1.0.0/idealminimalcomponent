#!/bin/bash
# Web4TSComponent CLI Tool - Location Independent Version
# Web4 pattern: Works from any directory, finds project root via git
# Based on proven test component pattern

# DRY: Source shared project root discovery library
# @pdca 2025-11-05-UTC-2301.dry-shell-libraries.pdca.md
# Get script's own directory to find lib-project-root.sh
SCRIPT_FILE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_FILE" ]; do
    SCRIPT_FILE="$(readlink "$SCRIPT_FILE")"
    if [[ "$SCRIPT_FILE" != /* ]]; then
        SCRIPT_FILE="$(dirname "${BASH_SOURCE[0]}")/$SCRIPT_FILE"
    fi
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_FILE")" && pwd -P)"

# Source the library (all components have it)
LIB_PATH="$SCRIPT_DIR/src/sh/lib-project-root.sh"
if [ ! -f "$LIB_PATH" ]; then
    echo "❌ ERROR: Required library not found: $LIB_PATH"
    echo "💡 Component installation may be corrupted"
    exit 1
fi
. "$LIB_PATH"

# PROJECT_ROOT is now available (set by library)
# SCRIPT_DIR already resolved above (reuse it - DRY!)

# Get component version from directory name (single source of truth)
COMPONENT_VERSION="$(basename "$SCRIPT_DIR")"
COMPONENT_PATH="$SCRIPT_DIR"

# Auto-source component's environment if needed
# Check if environment is loaded by testing for completion functions
SOURCE_ENV_PATH="$COMPONENT_PATH/source.env"
if [ -f "$SOURCE_ENV_PATH" ]; then
    # Check if source.env was already sourced by testing for completion function
    # The completion function is defined by source.env and inherits to subshells
    if ! declare -F _web4_generic_completion > /dev/null 2>&1; then
        # Completion function not defined - need to source
        source "$SOURCE_ENV_PATH"
    fi
    # Silent when already loaded (no message spam on repeated calls)
fi


# Verify component exists
if [ ! -d "$COMPONENT_PATH" ]; then
    echo "❌ Web4TSComponent $COMPONENT_VERSION not found at $COMPONENT_PATH"
    echo "🔍 Project root: $PROJECT_ROOT"
    exit 1
fi

# Change to component directory and use smart build system
cd "$COMPONENT_PATH" || {
    echo "❌ Failed to cd to $COMPONENT_PATH"
    echo "   Current dir: $(pwd)"
    exit 1
}

# Use our smart build system (handles freshness, dependencies, everything)
./src/sh/build.sh

# Check if CLI is available after smart build
CLI_PATH="dist/ts/layer5/IdealMinimalComponentCLI.js"
if [ ! -f "$CLI_PATH" ]; then
    echo "❌ IdealMinimalComponent CLI build failed"
    exit 1
fi

# Execute CLI with all arguments
node "$CLI_PATH" "$@"
