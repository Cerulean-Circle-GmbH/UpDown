#!/bin/bash
# Web4Articles Project Environment Setup
# Version: 0.3.13.1 (MUST manually update when template changes)
# TypeScript-first approach: Minimal shell, maximum TypeScript

# Useful aliases
alias ll='ls -la'

# Project Root - Required for tab completion bootstrap
export WEB4_PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Add scripts to PATH
export PATH="$WEB4_PROJECT_ROOT/scripts:$WEB4_PROJECT_ROOT/scripts/versions:$PATH"

echo "🔨 Web4 scripts added to PATH"

# ============================================================================
# 🎯 Tab Completion Setup for Web4 CLIs
# ============================================================================

# Load bash-completion framework if available
_web4_load_bash_completion() {
    type _init_completion &>/dev/null && return 0
    local paths=(
        "/usr/share/bash-completion/bash_completion"
        "/etc/bash_completion"
        "/opt/homebrew/etc/profile.d/bash_completion.sh"
        "/usr/local/etc/bash_completion"
        "/usr/local/etc/profile.d/bash_completion.sh"
    )
    for p in "${paths[@]}"; do
        [ -f "$p" ] && . "$p" && return 0
    done
    return 1
}

# Generic TSCompletion-based completion function
_web4_tscompletion() {
    local component="$1" cli="$2"
    local cur="${COMP_WORDS[COMP_CWORD]}" args=("${COMP_WORDS[@]:1}")
    local tsc="$WEB4_PROJECT_ROOT/components/$component/latest/src/ts/layer4/TSCompletion.ts"
    local logfile="$WEB4_PROJECT_ROOT/temp/logs/completion-debug.log"

    # Ensure our log directory exists (source.env owns this requirement)
    mkdir -p "$(dirname "$logfile")" 2>/dev/null || true
    
    # Color definitions for OOSH-style command line display (DRY - defined once)
    # Use DefaultCLI color scheme: [1;36m=command, [0;37m=method, [1;33m=parameters
    local BRIGHT_CYAN='\033[1;36m'
    local WHITE='\033[0;37m'
    local BRIGHT_YELLOW='\033[1;33m'
    local GREEN='\033[0;32m'
    local RED='\033[31m'
    local NO_COLOR='\033[0m'
    
    # Helper function: Apply colors to command line (DRY - reused by both completion paths)
    _web4_color_command_line() {
        local current_line="$1"
        local colored_cmd=""
        local i=0 word_num=0
        local in_word=false current_word=""
        
        while [ $i -lt ${#current_line} ]; do
            local char="${current_line:$i:1}"
            
            if [[ "$char" == " " ]]; then
                if [ "$in_word" = true ]; then
                    if [ $word_num -eq 0 ]; then
                        colored_cmd+="${BRIGHT_CYAN}${current_word}${NO_COLOR}"
                    elif [ $word_num -eq 1 ]; then
                        colored_cmd+="${WHITE}${current_word}${NO_COLOR}"
                    else
                        colored_cmd+="${BRIGHT_YELLOW}${current_word}${NO_COLOR}"
                    fi
                    ((word_num++))
                    current_word=""
                    in_word=false
                fi
                colored_cmd+=" "
            else
                current_word+="$char"
                in_word=true
            fi
            ((i++))
        done
        
        if [ "$in_word" = true ]; then
            if [ $word_num -eq 0 ]; then
                colored_cmd+="${BRIGHT_CYAN}${current_word}${NO_COLOR}"
            elif [ $word_num -eq 1 ]; then
                colored_cmd+="${WHITE}${current_word}${NO_COLOR}"
            else
                colored_cmd+="${BRIGHT_YELLOW}${current_word}${NO_COLOR}"
            fi
        fi
        
        echo "$colored_cmd"
    }
    
    # Debug logging
    {
        echo "=== $(date '+%Y-%m-%d %H:%M:%S') ==="
        echo "Component: $component"
        echo "CLI: $cli"
        echo "Current word (cur): '$cur'"
        echo "COMP_CWORD: $COMP_CWORD"
        echo "COMP_WORDS: ${COMP_WORDS[*]}"
        echo "Args (after CLI): ${args[*]}"
    } >> "$logfile" 2>&1
    
    [ ! -f "$tsc" ] && {
        echo "ERROR: TSCompletion not found at $tsc" >> "$logfile"
        return 0
    }
    
    # INJECT class name as first arg for TSCompletion
    # TSCompletion expects: [className, methodName, ...params]
    # Use comma-separated list (Web4 standard) to get BOTH CLI and component methods
    # User types: web4tscomponent links <Tab>
    # We inject: Web4TSComponentCLI,DefaultWeb4TSComponent links <Tab>
    # TSCompletion scans CLI extends hierarchy: Web4TSComponentCLI → DefaultCLI (auto-discovered)
    local className="${component}CLI,Default${component}"
    local completeArgs=("$className" "${args[@]}")
    
    {
        echo "ClassName injected: $className"
        echo "Complete args to TSCompletion: ${completeArgs[*]}"
    } >> "$logfile"
    
    # OOSH Pattern: Immediate user feedback before slow TypeScript call
    # Suppress message on double-tab (rapid successive identical calls)
    local cache_key="$cli:${args[*]}"
    local current_time=$(date +%s)
    local last_completion_key="${cache_key}"
    local last_completion_time="${current_time}"
    
    # Check if this is a rapid repeat (double-tab scenario)
    if [[ "${_WEB4_LAST_COMPLETION_KEY:-}" == "$cache_key" ]]; then
        local time_diff=$((current_time - ${_WEB4_LAST_COMPLETION_TIME:-0}))
        if [ $time_diff -le 2 ]; then
            # Suppress message on double-tab within 2 seconds
            :
        else
            printf "\n🔍 Calculating completions for: \`$cli ${args[*]}\`\n"
        fi
    else
        printf "\n🔍 Calculating completions for: \`$cli ${args[*]}\`\n"
    fi
    
    # Cache this completion call
    export _WEB4_LAST_COMPLETION_KEY="$cache_key"
    export _WEB4_LAST_COMPLETION_TIME="$current_time"
    
    local out=$(NODE_NO_WARNINGS=1 node --loader ts-node/esm "$tsc" "${completeArgs[@]}" 2>>"$logfile" || true)
    
    {
        echo "TSCompletion raw output: '$out'"
    } >> "$logfile"
    
    # Check if TSCompletion returned a callback hint
    if [[ "$out" == __CALLBACK__:* ]]; then
        local callback="${out#__CALLBACK__:}"
        {
            echo "Detected callback: $callback"
            echo "Calling: $cli completeParameter $callback ${args[*]}"
        } >> "$logfile"
        
        # OOSH Pattern: Immediate feedback for slow callback execution
        printf "🎯 Executing completion callback: \`$cli completeParameter $callback ${args[*]}\`\n"
        printf "💭 Thinking...\n"
        
        # Call TypeScript to execute the completion callback (Web4 pattern: @cliHide not __ prefix)
        # Pass all args (e.g., 'on Unit') so completion method has context
        # Preserve trailing newlines by adding a marker and removing it
        out=$($cli completeParameter "$callback" "${args[@]}" 2>>"$logfile"; echo "PRESERVE_NEWLINES" || true)
        out="${out%PRESERVE_NEWLINES}"
        {
            echo "Callback returned: '$out'"
        } >> "$logfile"
    fi
    
    {
        echo "Final output for compgen: '$out'"
    } >> "$logfile"
    
    # Smart Hybrid Detection (OOSH-inspired pattern)
    # If output contains newlines → Multi-LINE completion (hierarchical display)
    # Otherwise → Standard single-word completion (use compgen filtering)
    if [[ "$out" == *$'\n'* ]]; then
        {
            echo "Multi-LINE completion detected (OOSH pattern)"
            echo "Using printf for colored display + clean tokens for COMPREPLY"
        } >> "$logfile"
        
        # OOSH Pattern: Show colored hierarchy to user via printf
        printf "\n%s\n" "$out"
        
        # OOSH Command Line Display (like OOSH does) - NO trailing newline
        # Apply colors using DRY helper function
        local current_line="${COMP_LINE:0:$COMP_POINT}"
        local colored_cmd=$(_web4_color_command_line "$current_line")
        
        printf "\nyour ${BRIGHT_CYAN}web4${NO_COLOR} command > $colored_cmd${RED}${COMP_LINE:$COMP_POINT}${NO_COLOR}"
        
        # Extract clean tokens for COMPREPLY (look for patterns like "1a", "17b")
        local tokens=()
        while IFS= read -r line; do
            if [[ "$line" =~ ^[[:space:]]*([0-9]+[a-z])\) ]]; then
                tokens+=("${BASH_REMATCH[1]}")
            fi
        done <<< "$out"
        
        # Add space to tokens for multi-line completions (cursor positioning)
        if [ ${#tokens[@]} -gt 0 ]; then
            for i in "${!tokens[@]}"; do
                tokens[i]+=" "
            done
        fi
        
        # Set COMPREPLY to prevent default completion
        COMPREPLY=("${tokens[@]}")
        return 0
        
    else
        {
            echo "Single-word completion detected (standard pattern)"
            echo "Using compgen-based filtering"
        } >> "$logfile"
        
        # OOSH Command Line Display for single-word completions too
        # Apply colors using DRY helper function
        local current_line="${COMP_LINE:0:$COMP_POINT}"
        local colored_cmd=$(_web4_color_command_line "$current_line")
        
        printf "\nyour ${BRIGHT_CYAN}web4${NO_COLOR} command > $colored_cmd${RED}${COMP_LINE:$COMP_POINT}${NO_COLOR}"
        
        # Standard Pattern: Use compgen for prefix filtering
        # Works for simple single-word completions (backward compatible)
        COMPREPLY=( $(compgen -W "$out" -- "$cur") )
        
        # Note: Spacing handled by bash completion flags, no manual addition needed
    fi
    
    {
        echo "COMPREPLY (after hybrid completion with cur='$cur'): ${COMPREPLY[*]}"
        echo "COMPREPLY count: ${#COMPREPLY[@]}"
        echo "---"
    } >> "$logfile"
    
    # Only enable default completions (files/dirs) if we have NO custom completions
    # This prevents mixing our completion values with random files/directories
    if [ ${#COMPREPLY[@]} -eq 0 ]; then
        compopt -o default 2>/dev/null || true
    fi
}

# Auto-register completions for all CLIs
_web4_register_completions() {
    local scripts="$WEB4_PROJECT_ROOT/scripts" registered=()
    [ ! -d "$scripts" ] && return 0
    
    for cli in "$scripts"/*; do
        [ -x "$cli" ] && [ ! -d "$cli" ] || continue
        local name=$(basename "$cli")
        [[ "$name" =~ -v[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+ ]] && continue
        
        if [ -L "$cli" ]; then
            local target=$(readlink "$cli")
            if [[ "$target" =~ components/([^/]+)/latest ]]; then
                local comp="${BASH_REMATCH[1]}"
                local tsc="$WEB4_PROJECT_ROOT/components/$comp/latest/src/ts/layer4/TSCompletion.ts"
                if [ -f "$tsc" ]; then
                    eval "_${name}_completion() { _web4_tscompletion '$comp' '$name'; }"
                    complete -F "_${name}_completion" "$name" -o nospace
                    registered+=("$name")
                fi
            fi
        fi
    done
    
    [ ${#registered[@]} -gt 0 ] && echo "🎯 Tab completion enabled for: ${registered[*]}"
}

# Initialize completions (suppress all errors from bash-completion framework)
_web4_load_bash_completion >/dev/null 2>&1 || true
_web4_register_completions

# OOSH-inspired colored PS1 prompt for Web4
export PS1="\[\e[0m\][web4 \[\e[36m\]\u\[\e[0m\]@\[\e[32m\]\h\[\e[0m\]] \[\e[33;1m\]\w\[\e[0m\] > "

echo "✅ Web4 environment loaded (TypeScript-first, no ENV vars)"

# OOSH-style welcome message at the bottom (like OOSH bashrc)
echo -e "\033[36m
    🚀 Welcome to Web4 OOP Shell
    ✨ TypeScript-first development environment
    🎯 Tab completion with hierarchical display

\033[0m"