#!/bin/bash
# Web4 Project Environment Setup
# TypeScript-first approach: Minimal shell, maximum TypeScript
# Auto-generated by Web4TSComponent

# Useful aliases
alias ll='ls -la'

# Project Root - Required for tab completion bootstrap
export WEB4_PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Add scripts to PATH
export PATH="$WEB4_PROJECT_ROOT/scripts:$WEB4_PROJECT_ROOT/scripts/versions:$PATH"

echo "🔨 Web4 scripts added to PATH"

# ============================================================================
# 🎯 Tab Completion Setup for Web4 CLIs
# ============================================================================

# Load bash-completion framework if available
_web4_load_bash_completion() {
    type _init_completion &>/dev/null && return 0
    local paths=(
        "/usr/share/bash-completion/bash_completion"
        "/etc/bash_completion"
        "/opt/homebrew/etc/profile.d/bash_completion.sh"
        "/usr/local/etc/bash_completion"
        "/usr/local/etc/profile.d/bash_completion.sh"
    )
    for p in "${paths[@]}"; do
        [ -f "$p" ] && . "$p" && return 0
    done
    return 1
}

# Generic TSCompletion-based completion function
_web4_tscompletion() {
    local component="$1" cli="$2"
    local cur="${COMP_WORDS[COMP_CWORD]}" args=("${COMP_WORDS[@]:1}")
    local tsc="$WEB4_PROJECT_ROOT/components/$component/latest/src/ts/layer4/TSCompletion.ts"
    local logfile="$WEB4_PROJECT_ROOT/temp/logs/completion-debug.log"
    
    # Debug logging
    {
        echo "=== $(date '+%Y-%m-%d %H:%M:%S') ==="
        echo "Component: $component"
        echo "CLI: $cli"
        echo "Current word (cur): '$cur'"
        echo "COMP_CWORD: $COMP_CWORD"
        echo "COMP_WORDS: ${COMP_WORDS[*]}"
        echo "Args (after CLI): ${args[*]}"
    } >> "$logfile" 2>&1
    
    [ ! -f "$tsc" ] && {
        echo "ERROR: TSCompletion not found at $tsc" >> "$logfile"
        return 0
    }
    
    # INJECT class name as first arg for TSCompletion
    # TSCompletion expects: [className, methodName, ...params]
    # Use comma-separated list (Web4 standard) to get BOTH CLI and component methods
    # User types: web4tscomponent links <Tab>
    # We inject: DefaultCLI,DefaultWeb4TSComponent links <Tab>
    local className="DefaultCLI,Default${component}"
    local completeArgs=("$className" "${args[@]}")
    
    {
        echo "ClassName injected: $className"
        echo "Complete args to TSCompletion: ${completeArgs[*]}"
    } >> "$logfile"
    
    local out=$(NODE_NO_WARNINGS=1 node --loader ts-node/esm "$tsc" "${completeArgs[@]}" 2>>"$logfile" || true)
    
    {
        echo "TSCompletion raw output: '$out'"
    } >> "$logfile"
    
    # Check if TSCompletion returned a callback hint
    if [[ "$out" == __CALLBACK__:* ]]; then
        local callback="${out#__CALLBACK__:}"
        {
            echo "Detected callback: $callback"
            echo "Calling: $cli completeParameter $callback"
        } >> "$logfile"
        # Call TypeScript to execute the completion callback (Web4 pattern: @cliHide not __ prefix)
        out=$($cli completeParameter "$callback" 2>>"$logfile" || true)
        {
            echo "Callback returned: '$out'"
        } >> "$logfile"
    fi
    
    {
        echo "Final output for compgen: '$out'"
    } >> "$logfile"
    
    COMPREPLY=( $(compgen -W "$out" -- "$cur") )
    
    {
        echo "COMPREPLY (after compgen with cur='$cur'): ${COMPREPLY[*]}"
        echo "COMPREPLY count: ${#COMPREPLY[@]}"
        echo "---"
    } >> "$logfile"
    
    # Only enable default completions (files/dirs) if we have NO custom completions
    # This prevents mixing our completion values with random files/directories
    if [ ${#COMPREPLY[@]} -eq 0 ]; then
        compopt -o default 2>/dev/null || true
    fi
}

# Auto-register completions for all CLIs
_web4_register_completions() {
    local scripts="$WEB4_PROJECT_ROOT/scripts" registered=()
    [ ! -d "$scripts" ] && return 0
    
    for cli in "$scripts"/*; do
        [ -x "$cli" ] && [ ! -d "$cli" ] || continue
        local name=$(basename "$cli")
        [[ "$name" =~ -v[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+ ]] && continue
        
        if [ -L "$cli" ]; then
            local target=$(readlink "$cli")
            if [[ "$target" =~ components/([^/]+)/latest ]]; then
                local comp="${BASH_REMATCH[1]}"
                local tsc="$WEB4_PROJECT_ROOT/components/$comp/latest/src/ts/layer4/TSCompletion.ts"
                if [ -f "$tsc" ]; then
                    eval "_${name}_completion() { _web4_tscompletion '$comp' '$name'; }"
                    complete -F "_${name}_completion" "$name"
                    registered+=("$name")
                fi
            fi
        fi
    done
    
    [ ${#registered[@]} -gt 0 ] && echo "🎯 Tab completion enabled for: ${registered[*]}"
}

# Initialize completions (suppress all errors from bash-completion framework)
_web4_load_bash_completion >/dev/null 2>&1 || true
_web4_register_completions

echo "✅ Web4 environment loaded (TypeScript-first, no ENV vars)"

