{
  "name": "updown-qnd",
  "version": "0.3.0",
  "description": "UpDown Card Game - Quick & Dirty Prototype",
  "type": "module",
  "scripts": {
    "build": "esbuild src/public/ts/main.ts --bundle --format=esm --target=es2020 --outfile=src/public/dist/main.js --sourcemap --minify --tsconfig-raw='{\"compilerOptions\":{\"experimentalDecorators\":true,\"useDefineForClassFields\":false}}'",
    "build:watch": "esbuild src/public/ts/main.ts --bundle --format=esm --target=es2020 --outfile=src/public/dist/main.js --sourcemap --watch",
    "start": "npm run build && bash ./src/sh/updown.sh",
    "stop": "bash ./src/sh/stop.sh",
    "dev": "tsx watch src/ts/server/server.ts"
  },
  "keywords": [
    "card-game",
    "pwa",
    "https"
  ],
  "author": "Web4Games",
  "license": "MIT",
  "dependencies": {
    "@types/ws": "^8.18.1",
    "lit": "^3.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "esbuild": "^0.19.11",
    "tsx": "^4.19.2"
  }
}
