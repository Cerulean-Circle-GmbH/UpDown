{
  "name": "updown-qnd",
  "version": "0.3.0",
  "description": "UpDown Card Game - Quick & Dirty Prototype",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.client.json",
    "build:watch": "tsc --project tsconfig.client.json --watch",
    "start": "npm run build && bash ./src/sh/updown.sh",
    "stop": "bash ./src/sh/stop.sh",
    "dev": "tsx watch src/ts/server/server.ts"
  },
  "keywords": ["card-game", "pwa", "https"],
  "author": "Web4Games",
  "license": "MIT",
  "dependencies": {
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.3.3"
  }
}
